# Clé OpenAI (même clé que le projet lylo-agent)
OPENAI_API_KEY=

PORT=8000

# MySQL (chemins / URLs des images fond, logo, notes)
# En local, utiliser les variables individuelles ci-dessous.
# Sur Railway, définir MYSQL_URL (variable reference vers le plugin MySQL) suffit et prime sur les variables individuelles.
MYSQL_URL=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=ninno

# Cloudinary (stockage binaire des images: fond, logo, notes)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Jeton secret requis pour accéder aux routes /admin/* du back office
ADMIN_TOKEN=
